<Window x:Class="Govorun.Dialogs.FindFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govorun.Dialogs"
        mc:Ignorable="d"
        Title="Файлы книг"
        Width="700" Height="500" ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="300"
        d:Width="500" d:Height="300"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="ButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="75" />
                <Setter Property="Height" Value="25" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Папка -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="FolderButton" Content="Папка"
                    Style="{StaticResource ButtonStyle}"
                    Margin="0,0,10,0"
                    Click="FolderButton_Click" />
            <TextBox Grid.Column="1" x:Name="FolderTextBox"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Background="{StaticResource TextBoxReadOnlyBackgroundBrush}" />
            <Button Grid.Column="2" x:Name="FindButton" Content="Найти"
                    Style="{StaticResource ButtonStyle}"
                    IsEnabled="False"
                    Margin="10,0,0,0"
                    Click="FindButton_Click" />
        </Grid>

        <!-- Заголовок списка файлов -->
        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Файлы книг" Margin="2,0,0,0" />

            <StackPanel Grid.Column="1" x:Name="FoundStackPanel" Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="Найдено файлов:" />
                <TextBlock x:Name="CountTextBlock" Text="0" Margin="5,0,5,0" />
            </StackPanel>

            <TextBlock Grid.Column="1" x:Name="FindingTextBlock" Text="Поиск файлов..."
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Список файлов -->
        <ListBox Grid.Row="2" x:Name="FilesListBox"
                 ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                 SelectionChanged="FilesListBox_SelectionChanged" />

        <!-- Кнопки -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Button x:Name="BookButton" Content="Книга"
                    Style="{StaticResource ButtonStyle}"
                    IsEnabled="False"
                    HorizontalAlignment="Left"
                    Click="BookButton_Click" />
            <Button x:Name="CloseButton" Content="Закрыть"
                    Style="{StaticResource ButtonStyle}"
                    IsCancel="True"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click" />
        </Grid>

    </Grid>
</Window>
